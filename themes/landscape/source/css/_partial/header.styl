#header
  height: banner-height
  position: relative
  border-bottom: 1px solid rgba(180, 35, 47, 0.12)
  overflow: hidden
  &:before, &:after
    content: ""
    position: absolute
    left: 0
    right: 0
    height: 90px
  &:before
    top: 0
    background: linear-gradient(rgba(120, 0, 15, 0.14), transparent)
  &:after
    bottom: 0
    background: linear-gradient(transparent, rgba(120, 0, 15, 0.12))

  .sun-disc
    display: none

#header-outer:after
  content: ""
  position: absolute
  width: 260px
  height: 260px
  border-radius: 50%
  top: 42px
  right: 12%
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.65), rgba(255,255,255,0.05) 32%, rgba(217,71,82,0.92) 33%, rgba(180,35,47,0.95) 68%, rgba(130,12,25,0.95) 100%)
  box-shadow: 0 24px 60px rgba(180, 35, 47, 0.16)
  z-index: -1
  @media mq-mobile
    width: 180px
    height: 180px
    top: 70px
    right: -30px

#header-outer
  height: 100%
  position: relative

#header-inner
  position: relative
  overflow: hidden

#banner
  position: absolute
  top: 0
  left: 0
  width: 100%
  height: 100%
  background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.45), rgba(255, 255, 255, 0.08)), url(banner-url)
  background-color: #fff5f2
  background-position: center
  background-size: cover
  z-index: -1
  &:before
    content: ""
    position: absolute
    inset: 0
    background: linear-gradient(90deg, rgba(255,252,251,0.94) 0%, rgba(255,247,244,0.82) 35%, rgba(255,245,242,0.3) 62%, rgba(255,245,242,0) 100%)
  &:after
    content: ""
    position: absolute
    left: 10%
    bottom: 44px
    width: 220px
    height: 2px
    background: linear-gradient(90deg, rgba(180,35,47,0.45), rgba(180,35,47,0))
    box-shadow: 0 -14px 0 rgba(180,35,47,0.09), 0 14px 0 rgba(180,35,47,0.09)
    @media mq-mobile
      width: 120px

#header-title
  text-align: left
  height: logo-size
  position: absolute
  top: 50%
  left: 0
  margin-top: logo-size * -0.5
  width: 100%
  max-width: 520px
  padding-left: 8%
  box-sizing: border-box
  @media mq-mobile
    padding-left: 24px
    max-width: calc(100% - 36px)

$logo-text
  text-decoration: none
  color: #7d1521
  font-weight: 300
  text-shadow: 0 8px 24px rgba(255, 255, 255, 0.65)

#logo
  @extend $logo-text
  font-size: logo-size
  line-height: logo-size
  letter-spacing: 3px
  font-family: font-serif
  &:before
    content: ""
    display: inline-block
    width: 14px
    height: 14px
    border-radius: 50%
    background: #b4232f
    margin-right: 12px
    vertical-align: middle
    box-shadow: 0 0 0 7px rgba(180,35,47,0.08)

#subtitle
  @extend $logo-text
  font-size: subtitle-size
  line-height: subtitle-size
  letter-spacing: 0.28em
  color: #9e4d54
  text-transform: uppercase

#subtitle-wrap
  margin-top: 18px

#main-nav
  float: left
  margin-left: -15px

$nav-link
  float: left
  color: #8c1b26
  opacity: 0.8
  text-decoration: none
  text-shadow: 0 1px rgba(255, 255, 255, 0.6)
  transition: opacity 0.2s
  display: block
  padding: 20px 15px
  &:hover
    opacity: 1
    color: color-link

.nav-icon
  @extend $nav-link
  text-align: center
  font-size: font-size
  width: font-size
  height: font-size
  padding: 20px 15px
  position: relative
  cursor: pointer

.main-nav-link
  @extend $nav-link
  font-weight: 600
  letter-spacing: 0.12em
  margin-top: 10px
  border-radius: 999px
  padding: 10px 16px
  background: rgba(255,255,255,0.3)
  border: 1px solid rgba(180,35,47,0.08)
  @media mq-mobile
    display: none

#main-nav-toggle
  display: none
  @media mq-mobile
    display: block

#sub-nav
  float: right
  margin-right: -15px

#search-form-wrap
  position: absolute
  top: 15px
  width: 150px
  height: 30px
  right: -150px
  opacity: 0
  transition: 0.2s ease-out
  &.on
    opacity: 1
    right: 0
  @media mq-mobile
    width: 100%
    right: -100%

.search-form
  position: absolute
  top: 0
  left: 0
  right: 0
  background: #fff
  padding: 5px 15px
  border-radius: 999px
  box-shadow: 0 14px 30px rgba(149, 32, 44, 0.12)

.search-form-input
  border: none
  background: none
  color: color-default
  width: 100%
  font: 13px font-sans
  outline: none
  &::-webkit-search-results-decoration
  &::-webkit-search-cancel-button
    -webkit-appearance: none

.search-form-submit
  position: absolute
  top: 50%
  right: 10px
  margin-top: -7px
  font: 13px font-icon
  border: none
  background: none
  color: #c07b7b
  cursor: pointer
  &:hover, &:focus
    color: color-link
