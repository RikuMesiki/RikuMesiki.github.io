#sidebar
  @media mq-normal
    column(sidebar-column)

.widget-wrap
  margin: block-margin 0

.widget-title
  @extend $block-caption

.widget
  color: color-sidebar-text
  text-shadow: none
  background: color-widget-background
  box-shadow: 0 10px 30px rgba(167, 43, 53, 0.06)
  border: 1px solid color-widget-border
  padding: 18px
  border-radius: 18px
  a
    color: color-link
    text-decoration: none
    &:hover
      text-decoration: underline
  ul, ol, dl
    ul, ol, dl
      margin-left: 15px
      list-style: disc
