#footer
  background: color-footer-background
  padding: 50px 0
  border-top: 1px solid rgba(255,255,255,0.18)
  color: rgba(255,255,255,0.8)
  position: relative
  overflow: hidden
  &:before
    content: ""
    position: absolute
    width: 220px
    height: 220px
    border-radius: 50%
    right: -60px
    top: -80px
    background: rgba(209,31,70,0.16)
  a
    color: #ffe3de
    text-decoration: none
    &:hover
      text-decoration: underline

#footer-info
  line-height: line-height
  font-size: 0.85em
